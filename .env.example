# ========== 链易配 配置模板 ==========
# 复制本文件为 .env，按需修改密码。.env 已被 .gitignore 排除，勿提交。

# ========== 数据库 ==========
# MySQL（必填）
# 格式: mysql+pymysql://用户名:密码@主机/数据库名
# Windows 注意: pymysql 连接无需特殊转义
# macOS (Homebrew MySQL): 默认安装后设置密码，或用 socket 认证
DATABASE_URL=mysql+pymysql://root:你的MySQL密码@localhost/lianyipei

# Neo4j（产业链图谱功能需要，非必须）
# 安装: brew install neo4j (macOS) 或 Neo4j Desktop (Windows)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=你的Neo4j密码

# Redis（可选，用于定时任务缓存）
REDIS_URL=redis://localhost:6379/0

# ========== Flask ==========
SECRET_KEY=change-this-to-random-string-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# 本地联调：跳过登录验证（上线前务必关闭）
# DISABLE_API_AUTH=1
# DEV_API_LOGIN_ENTERPRISE_ID=1

# ========== 大模型（Ollama 本地部署）==========
# 安装 Ollama:
#   macOS:  brew install ollama
#   Windows: https://ollama.com/download/windows
# 拉取模型:
#   ollama pull qwen2:7b    (7B 参数，约 4.4GB)
#   ollama pull qwen2.5:3b  (3B 参数，约 1.9GB，轻量备选)
# 验证: ollama list

# Ollama 服务地址（默认端口 11434）
# 远端 GPU 服务器示例: http://192.168.1.100:11434
OLLAMA_BASE_URL=http://localhost:11434

# 模型名须与 `ollama list` 中 name 列完全一致
# 推荐按需选择: qwen2:7b / qwen2.5:3b / qwen2.5:7b
OLLAMA_MODEL=qwen2:7b
BIZMIND_OLLAMA_MODEL=qwen2:7b

# 超时与 token 控制
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0

# ========== 外部 API（可选，竞赛展演可不填）==========
# DeepSeek API（备用 LLM）
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# AnythingLLM（可选知识库，竞赛展演可不填）
# ANYTHING_LLM_API_KEY=
# ANYTHING_LLM_WORKSPACE=default
# ANYTHING_LLM_BASE_URL=http://127.0.0.1:3001

# ========== 微信推送（可选，竞赛展演可不填）==========
# 企业微信
# WORK_WECHAT_CORPID=
# WORK_WECHAT_CORPSECRET=
# WORK_WECHAT_AGENTID=

# 微信服务号
# WECHAT_SERVICE_APPID=
# WECHAT_SERVICE_SECRET=
# WECHAT_TEMPLATE_ID=
# WECHAT_TEMPLATE_DATA_KEYS=thing1,time2

# ========== 高德地图（可选）==========
# AMAP_JS_KEY=
# AMAP_SECURITY_JS_CODE=
# AMAP_SERVICE_KEY=
